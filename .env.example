# ModelX environment configuration
# Copy to .env and fill in values. All variables have sensible defaults
# except OPENROUTER_API_KEY which is required.

# --- API keys ---
OPENROUTER_API_KEY=sk-or-...

# --- Timing ---
# Global phase duration in seconds (each tick fires one MM or HF phase).
# YAML values override this if present.
PHASE_DURATION_SECONDS=180

# --- News / price data ---
# Max headlines fetched per cycle (YAML per-market value overrides this).
MAX_HEADLINES_PER_CYCLE=10
# yfinance download parameters for price series.
PRICE_PERIOD=2d
PRICE_INTERVAL=30m
# Number of most-recent OHLCV rows to include.
PRICE_LOOKBACK=24

# --- Agent ---
# HTTP timeout (seconds) for OpenRouter LLM calls.
OPENROUTER_TIMEOUT=60

# --- Paths ---
# Defaults for CLI arguments; CLI flags still override these.
DB_PATH=modelx.db
MARKETS_YAML=markets.yaml
AGENTS_YAML=agents.yaml
CONTRACT_YAML=contracts.yaml
